---
import '@/styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const SITE_URL = 'https://codevetter.com';

const {
  title = 'CodeVetter — Vet AI-generated code before it ships',
  description = 'Desktop-first code review for agent-generated code. Runs offline. Multi-LLM. Catches what your agent misses.',
  path = '/',
} = Astro.props;

// Clamp meta description to 70–160 chars for SEO best practice.
const DEFAULT_DESC = 'Desktop-first code review for agent-generated code. Runs offline. Multi-LLM. Catches what your agent misses.';
function clampDescription(desc: string, fallback: string = DEFAULT_DESC): string {
  let d = (desc ?? '').trim();
  if (d.length === 0) return fallback;
  if (d.length > 160) {
    d = d.slice(0, 157).replace(/\s+\S*$/, '').trim();
    if (d.length > 0) d += '…';
    return d;
  }
  if (d.length < 70) {
    const f = fallback.trim();
    if (f.length >= 70 && f.length <= 160) return f;
    if (d.length > 0 && f.length > 0) {
      const combined = `${d}. ${f}`;
      if (combined.length <= 160) return combined;
      return combined.slice(0, 157).replace(/\s+\S*$/, '').trim() + '…';
    }
    return f || d;
  }
  return d;
}
const clampedDescription = clampDescription(description);

const canonical = `${SITE_URL}${path === '/' ? '' : path}`;
// Reuse the OG image generated by the old Next.js build at
// https://codevetter.com/opengraph-image. Post-cutover, the CF Pages
// project serves /, so this absolute URL falls back to a stable image
// asset if we publish one to public/og.png later. For now, keep the
// existing visual contract.
const OG_IMAGE = `${SITE_URL}/og-image.png`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={clampedDescription} />
    <meta name="application-name" content="CodeVetter" />
    <meta name="keywords" content="AI code review, agent code review, desktop code review, AI code security, vulnerability scanner, Cursor alternative, Claude Code review, Devin review, diff review tool, offline code review" />
    <meta name="author" content="CodeVetter" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="CodeVetter" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={clampedDescription} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={clampedDescription} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:site" content="@sarthakcodes" />
    <meta name="twitter:creator" content="@sarthakcodes" />

  <!-- fleet-jsonld:start (generated by apply-agent-surfaces; edit registry, not this) -->
<script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://sassmaker.com/#org","name":"SaaS Maker (Foundry)","url":"https://sassmaker.com","sameAs":["https://sassmaker.com","https://github.com/Codevetter/codevetter"]},{"@type":"SoftwareApplication","@id":"https://codevetter.com/#app","name":"CodeVetter","url":"https://codevetter.com","description":"Desktop-first AI code review workbench for agent-generated code. Local SQLite, Tauri shell, evidence-backed review — your repo never hits a central server.","publisher":{"@id":"https://sassmaker.com/#org"},"applicationCategory":"DeveloperApplication","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}}]}</script>
<!-- fleet-jsonld:end -->
</head>
  <body>
    <slot />
  </body>
</html>
