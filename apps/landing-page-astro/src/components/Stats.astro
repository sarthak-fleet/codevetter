---
// Port of apps/landing-page/components/organisms/Stats.tsx.
const items = [
  { k: '0ms', v: 'Cloud round-trip', sub: 'the review runs on your device' },
  { k: '3+', v: 'LLM providers', sub: 'anthropic · openai · openrouter' },
  { k: '100%', v: 'Code stays local', sub: 'no proxy, no telemetry' },
  { k: '$0', v: 'To run forever', sub: 'bring your own LLM key' },
];
---

<section class="relative overflow-hidden bg-[#0A0A0A] py-16">
  <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {items.map((it) => (
        <div class="relative group p-6 rounded-3xl hover:bg-white/[0.02] transition-colors duration-500">
          <div class="font-display text-4xl md:text-5xl font-bold text-white group-hover:text-blue-400 transition-colors duration-500 tabular-nums mb-3 tracking-tighter">
            {it.k}
          </div>
          <div class="text-xs font-bold text-gray-300 uppercase tracking-widest mb-1 group-hover:text-white transition-colors">
            {it.v}
          </div>
          <div class="text-xs text-gray-500 font-medium">
            {it.sub}
          </div>
          <div class="absolute bottom-0 left-6 right-6 h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>
