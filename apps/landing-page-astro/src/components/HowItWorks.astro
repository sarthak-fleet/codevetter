---
import Icon from './Icon.astro';

// Port of apps/landing-page/components/organisms/HowItWorks.tsx.

const steps = [
  {
    n: '01',
    title: 'Drop in your diff',
    body: 'Stage changes, paste a patch, or hand it a branch range. CodeVetter parses files, hunks, and call-sites locally.',
    code: '$ codevetter review HEAD~1..HEAD',
    icon: 'terminal',
  },
  {
    n: '02',
    title: 'Pick the model',
    body: 'Choose Claude, GPT, or anything OpenRouter routes. Switch per-review. We track token usage live and never proxy it.',
    code: '→ provider=anthropic model=claude-3-opus',
    icon: 'zap',
  },
  {
    n: '03',
    title: 'Triage the verdict',
    body: 'Findings ranked by severity, mapped to CWE, with concrete patch diffs. Apply, edit, or dismiss with one keystroke.',
    code: '✓ 4 critical · 12 high · 29 medium',
    icon: 'shield-check',
  },
];
---

<section id="how" class="py-32 relative overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-6">
    <div class="max-w-3xl flex flex-col items-center mx-auto text-center">
      <div class="flex items-center gap-3 mb-6 bg-blue-500/10 border border-blue-500/20 px-4 py-1.5 rounded-full shadow-[0_0_15px_rgba(96,165,250,0.15)]">
        <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
        <span class="text-xs uppercase tracking-widest text-blue-400 font-semibold">
          Operating loop
        </span>
      </div>
      <h2 class="font-display text-[clamp(2.4rem,5vw,4.2rem)] font-bold leading-[1.05] tracking-tight">
        Three steps. <span class="text-gradient">Zero ceremony.</span>
      </h2>
      <p class="mt-6 text-[18px] text-gray-400 leading-relaxed max-w-2xl mx-auto">
        No accounts, no setup wizards. Open the app, plug in a key, ship safer code.
      </p>
    </div>

    <div class="mt-24 grid grid-cols-1 md:grid-cols-3 gap-12">
      {steps.map((s, i) => (
        <div class="relative group">
          <div class="absolute -inset-4 rounded-[2rem] bg-white/[0.02] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 mb-8 shadow-[0_0_20px_rgba(96,165,250,0.15)] group-hover:scale-110 transition-transform duration-500">
              <Icon name={s.icon} class="w-5 h-5" width={20} height={20} />
            </div>
            <div class="text-xs font-bold text-blue-500/50 uppercase tracking-[0.2em] mb-3">
              Step {s.n}
            </div>
            <h3 class="text-2xl font-bold text-white mb-4 tracking-tight">
              {s.title}
            </h3>
            <p class="text-gray-400 text-[15px] leading-relaxed mb-8">
              {s.body}
            </p>
            <div class="rounded-xl bg-black border border-white/5 p-4 font-mono text-xs shadow-inner">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-2 h-2 rounded-full bg-red-500/40"></div>
                <div class="w-2 h-2 rounded-full bg-amber-500/40"></div>
                <div class="w-2 h-2 rounded-full bg-emerald-500/40"></div>
              </div>
              <div class="text-blue-400/90 leading-relaxed break-all">
                {s.code}
              </div>
              {i === 0 && (
                <div class="mt-4 space-y-2 text-[11px] text-gray-500 border-t border-white/5 pt-4">
                  <div class="flex items-center justify-between">
                    <span>parsing diff</span>
                    <span class="text-emerald-500">✓</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span>resolving call-sites</span>
                    <span class="text-emerald-500">✓</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span>building context</span>
                    <span class="text-blue-400 animate-pulse">...</span>
                  </div>
                </div>
              )}
              {i === 1 && (
                <div class="mt-4 grid grid-cols-1 gap-2 border-t border-white/5 pt-4">
                  <div class="flex items-center justify-between px-2 py-1.5 rounded bg-blue-500/10 border border-blue-500/20 text-[10px] text-blue-400">
                    <span>claude-3-opus</span>
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
                  </div>
                  <div class="flex items-center justify-between px-2 py-1.5 rounded border border-white/5 text-[10px] text-gray-600">
                    <span>gpt-4o</span>
                    <span class="w-1.5 h-1.5 rounded-full bg-gray-700"></span>
                  </div>
                </div>
              )}
              {i === 2 && (
                <div class="mt-4 space-y-2 border-t border-white/5 pt-4">
                  <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-red-400/80">CRITICAL</span>
                    <span class="text-gray-500">04</span>
                  </div>
                  <div class="flex justify-between text-[10px] font-bold">
                    <span class="text-amber-400/80">HIGH</span>
                    <span class="text-gray-500">12</span>
                  </div>
                  <div class="flex justify-between text-[10px] font-bold border-t border-white/5 pt-2 mt-2">
                    <span class="text-emerald-400">PATCHES READY</span>
                    <span class="text-emerald-400">45</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
