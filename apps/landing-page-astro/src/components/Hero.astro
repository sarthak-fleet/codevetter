              <span class="w-2.5 h-2.5 rounded-full bg-[--color-warn]/40 border border-[--color-warn]/60"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-[--color-ok]/40 border border-[--color-ok]/60"></span>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="git-pull-request-arrow" class="w-3.5 h-3.5 text-[--color-text-mute]" width={14} height={14} strokeWidth={1.5} />
              <span class="label-mono">codevetter — review · feat/refresh-tokens · #1284</span>
            </div>
            <span class="label-mono">⌘ K</span>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-12 min-h-[540px]">
            {/* Pipeline + findings */}
            <aside class="hidden lg:flex lg:col-span-3 flex-col border-r border-white/5 bg-white/[0.01]">
              <div class="px-5 pt-5 pb-3 label-mono">Pipeline</div>
              <div class="px-5 space-y-2.5 pb-5 border-b border-[--color-line]">
                <div class="pipe-row">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[--color-ok]"></span>
                    <span class="text-[--color-text]">Diff parsed</span>
                  </span>
                  <span class="text-[--color-text-mute]">12ms</span>
                </div>
                <div class="pipe-row">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[--color-ok]"></span>
                    <span class="text-[--color-text]">AST traced</span>
                  </span>
                  <span class="text-[--color-text-mute]">84ms</span>
                </div>
                <div class="pipe-row">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[--color-accent] animate-pulse-soft"></span>
                    <span class="text-[--color-text]">LLM scoring</span>
                  </span>
                  <span class="text-[--color-text-mute]">1.4s</span>
                </div>
                <div class="pipe-row">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[--color-text-mute]/40"></span>
                    <span class="text-[--color-text-mute]">Severity tag</span>
                  </span>
                  <span class="text-[--color-text-mute]">—</span>
                </div>
                <div class="pipe-row">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[--color-text-mute]/40"></span>
                    <span class="text-[--color-text-mute]">Patch draft</span>
                  </span>
                  <span class="text-[--color-text-mute]">—</span>
                </div>
              </div>
              <div class="px-5 pt-5 pb-3 label-mono">Findings</div>
              <div class="px-5 space-y-2 pb-5 flex-1">
                <div class="find-row border-[--color-danger] text-[--color-danger]">
                  <div class="flex justify-between">
                    <span>V-0821</span>
                    <span>SQLi</span>
                  </div>
                  <div class="text-[--color-text-mute] truncate">session_manager.ts</div>
                </div>
                <div class="find-row border-[--color-warn] text-[--color-warn]">
                  <div class="flex justify-between">
                    <span>V-0822</span>
                    <span>PII-leak</span>
                  </div>
                  <div class="text-[--color-text-mute] truncate">logger.ts</div>
                </div>
                <div class="find-row border-[--color-warn] text-[--color-warn]">
                  <div class="flex justify-between">
                    <span>V-0823</span>
                    <span>Rate-limit</span>
                  </div>
                  <div class="text-[--color-text-mute] truncate">auth.ts</div>
                </div>
                <div class="find-row border-[--color-accent] text-[--color-accent]">
                  <div class="flex justify-between">
                    <span>V-0824</span>
                    <span>TTL drift</span>
                  </div>
                  <div class="text-[--color-text-mute] truncate">cache.ts</div>
                </div>
              </div>
              <div class="border-t border-[--color-line] px-5 py-3 flex items-center justify-between font-mono text-[10px]">
                <span class="text-[--color-text-mute] uppercase tracking-[0.18em]">Model</span>
                <span class="text-[--color-accent]">claude-opus-4-7</span>
              </div>
            </aside>

            {/* Code editor */}
            <div class="lg:col-span-6 border-b lg:border-b-0 lg:border-r border-[--color-line] relative overflow-hidden bg-[#050505]">
              <div class="absolute inset-0 pointer-events-none">
                <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-[--color-accent] to-transparent animate-scan"></div>
              </div>
              <div class="flex items-center justify-between px-4 py-3 border-b border-[--color-line] text-xs text-gray-400 font-mono">
                <div class="flex items-center gap-2">
                  <span class="px-1.5 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">vuln</span>
                  <span>apps/api/src/auth/session_manager.ts</span>
                </div>
                <span class="label-mono text-[--color-danger]">+2 / -0</span>
              </div>
              <div class="p-4 font-mono text-[13px] leading-relaxed text-gray-300">
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">36</div>
                  <div>
                    <span class="text-purple-400">import</span> &lbrace; db &rbrace;{' '}
                    <span class="text-purple-400">from</span>{' '}
                    <span class="text-green-400">"@/lib/sql"</span>;
                  </div>
                </div>
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">37</div>
                  <div></div>
                </div>
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">38</div>
                  <div>
                    <span class="text-purple-400">async function</span>{' '}
                    <span class="text-blue-400">validateSession</span>(token:{' '}
                    <span class="text-yellow-300">string</span>) &lbrace;
                  </div>
                </div>
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">39</div>
                  <div class="text-gray-500">  // resolve session for the incoming request</div>
                </div>

                <div class="relative flex bg-red-500/10 border-l-2 border-red-500 -ml-4 pl-4 py-1 mt-1">
                  <div class="w-8 text-right text-red-500/50 select-none mr-4">40</div>
                  <div>
                    <span class="text-purple-400">  const</span> query ={' '}
                    <span class="text-green-400">{'`SELECT * FROM sessions WHERE token = \'${token}\'`'}</span>;
                  </div>
                </div>
                <div class="relative flex bg-red-500/10 border-l-2 border-red-500 -ml-4 pl-4 py-1 mb-1">
                  <div class="w-8 text-right text-red-500/50 select-none mr-4">41</div>
                  <div>
                    <span class="text-purple-400">  const</span> result ={' '}
                    <span class="text-purple-400">await</span> db.execute(query);
                  </div>
                </div>

                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">42</div>
                  <div>
                    <span class="text-purple-400">  if</span> (!result.rows[
                    <span class="text-yellow-400">0</span>])
                    <span class="text-purple-400"> throw new</span> Error(
                    <span class="text-green-400">"Invalid session"</span>);
                  </div>
                </div>
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">43</div>
                  <div>
                    <span class="text-purple-400">  return</span> result.rows[
                    <span class="text-yellow-400">0</span>];
                  </div>
                </div>
                <div class="flex">
                  <div class="w-8 text-right text-gray-600 select-none mr-4">44</div>
                  <div>&rbrace;</div>
                </div>
              </div>

              <div class="absolute top-[170px] right-6 bg-[#1A1A1A] border border-white/10 rounded-xl shadow-2xl p-4 max-w-[280px] z-10 backdrop-blur-xl">
                <div class="flex items-center gap-2 mb-2">
                  <Icon name="shield-alert" class="w-4 h-4 text-red-400" width={16} height={16} />
                  <span class="text-sm font-semibold text-white">SQL Injection Vector</span>
                </div>
                <p class="text-xs text-gray-400 leading-relaxed mb-3">
                  Token concatenated directly into query body. Allows arbitrary read/write against sessions table.
                </p>
                <div class="bg-black/50 border border-white/5 rounded-lg p-2.5 font-mono text-[11px]">
                  <div class="text-emerald-400">+ db.query(`...$1`, [token])</div>
                </div>
              </div>
            </div>

            {/* Verdict sidebar */}
            <aside class="lg:col-span-3 p-6 bg-white/[0.01] space-y-6">
              <div>
                <div class="label-mono mb-4">Verdict</div>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 font-medium text-sm">
                  <Icon name="shield-alert" class="w-4 h-4" width={16} height={16} />
                  CRITICAL
                </div>
              </div>

              <div class="space-y-4">
                <div class="label-mono">Suggested actions</div>
                <button class="w-full py-2.5 px-4 rounded-lg bg-white text-black font-medium text-sm hover:bg-gray-100 transition-colors shadow-lg shadow-white/10">
                  Apply Patch
                </button>
                <button class="w-full py-2.5 px-4 rounded-lg bg-white/5 border border-white/10 text-white font-medium text-sm hover:bg-white/10 transition-colors">
                  Dismiss Finding
                </button>
              </div>

              <div class="pt-4 border-t border-white/5">
                <div class="label-mono mb-3">Tags</div>
                <div class="flex flex-wrap gap-2">
                  <span class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[10px] text-gray-300 font-mono">CWE-89</span>
                  <span class="px-2 py-1 rounded-md bg-white/5 border border-white/10 text-[10px] text-gray-300 font-mono">OWASP-A03</span>
                </div>
              </div>
            </aside>
          </div>

          {/* Stat strip */}
          <div class="border-t border-[--color-line] grid grid-cols-2 lg:grid-cols-4 divide-x divide-[--color-line] font-mono text-[11px]">
            <div class="hero-stat">
              <span class="label-mono">Critical</span>
              <span class="font-display text-2xl font-bold text-[--color-danger]">04</span>
            </div>
            <div class="hero-stat">
