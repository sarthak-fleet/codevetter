---
import Icon from './Icon.astro';

// Port of apps/landing-page/components/organisms/Hero.tsx.
// React-only effects dropped per static-port convention:
//   - framer-motion entrance animations → render end-state.
//   - ParticleField useMemo seed → compute the same deterministic
//     particles in frontmatter so they render at build time.
//   - Animated path stroke under "AI code." → render the full path.

const PARTICLE_COUNT = 30;
const particles = Array.from({ length: PARTICLE_COUNT }, (_, i) => {
  // Identical seeded RNG to the React ParticleField so the visual
  // layout is preserved.
  const seed = (n: number) => {
    const x = Math.sin(n * 9301 + 49297) * 233280;
    return x - Math.floor(x);
  };
  return {
    left: seed(i) * 100,
    top: seed(i + 1000) * 100,
    size: seed(i + 2000) * 2 + 1,
    delay: seed(i + 3000) * 6,
    duration: seed(i + 4000) * 6 + 6,
    opacity: seed(i + 5000) * 0.5 + 0.2,
  };
});
---

<section class="relative pt-32 pb-24 overflow-hidden">
  {/* LCP headline first in DOM — decor is absolutely positioned behind. */}
  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="flex flex-col items-center text-center">
