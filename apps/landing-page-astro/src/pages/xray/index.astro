---
import Footer from '@/components/Footer.astro';
import Nav from '@/components/Nav.astro';
import examples from '@/data/xray-examples.json';
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Agent PR X-Ray examples — CodeVetter"
  description="Static, evidence-traced examples exported locally from CodeVetter reviews."
  path="/xray/"
>
  <Nav />
  <main class="xray-shell">
    <header>
      <p class="eyebrow">Public proof, without repository uploads</p>
      <h1>See what the review can actually prove.</h1>
      <p class="lede">
        Agent PR X-Rays are static exports from completed local reviews. Every example keeps failed,
        waived, missing, and unverified stages visible instead of polishing them into a green badge.
      </p>
      <div class="actions">
        <a class="primary" href="/download/">Run CodeVetter locally</a>
        <a href="/benchmark/">Inspect all 27 benchmark cases</a>
      </div>
    </header>

    <section aria-labelledby="examples-heading">
      <div class="section-heading">
        <h2 id="examples-heading">Reviewed examples</h2>
        <span>Benchmark ground truth · static HTML</span>
      </div>
      <div class="grid">
        {examples.map((example) => (
          <a class="card" href={`/xray/${example.id}/`}>
            <div class="meta"><span>{example.language}</span><span>{example.category}</span></div>
            <h3>{example.title}</h3>
            <p>{example.finding.summary}</p>
            <div class="result">
              <span>{example.finding.severity}</span>
              <code>{example.finding.file}:{example.finding.line}</code>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .xray-shell{width:min(1120px,calc(100% - 40px));margin:0 auto;padding:150px 0 96px}.eyebrow{color:#d4a039;text-transform:uppercase;letter-spacing:.16em;font-size:.75rem;font-weight:650}header{max-width:760px}h1{font-size:clamp(2.8rem,7vw,5.6rem);line-height:.98;letter-spacing:-.065em;margin:20px 0;color:#f2f1ed}.lede{max-width:680px;color:#9a9ca3;font-size:1.1rem;line-height:1.7}.actions{display:flex;gap:14px;align-items:center;margin-top:32px}.actions a{color:#c9c9c5;text-decoration:none;padding:11px 16px;border:1px solid #28292d;border-radius:10px}.actions .primary{background:#d4a039;border-color:#d4a039;color:#111;font-weight:650}section{margin-top:100px}.section-heading{display:flex;align-items:end;justify-content:space-between;border-bottom:1px solid #242529;padding-bottom:18px}.section-heading h2{margin:0;color:#eeede9;font-size:1.55rem}.section-heading span{color:#707278;font-size:.78rem}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:18px}.card{display:flex;min-height:310px;flex-direction:column;padding:24px;border:1px solid #25262a;border-radius:16px;background:#101114;color:inherit;text-decoration:none;transition:transform .18s ease,border-color .18s ease}.card:hover{transform:translateY(-3px);border-color:#514428}.meta,.result{display:flex;justify-content:space-between;gap:12px;color:#8b8d94;font-size:.76rem}.card h3{color:#ecebe7;font-size:1.25rem;letter-spacing:-.025em;margin:42px 0 12px}.card p{color:#8f9198;line-height:1.6;margin:0}.result{margin-top:auto;padding-top:24px}.result span{color:#e1b75f;text-transform:uppercase;letter-spacing:.1em}.result code{color:#767980}@media(max-width:820px){.grid{grid-template-columns:1fr}.card{min-height:250px}.section-heading{align-items:start;gap:10px;flex-direction:column}}
</style>
