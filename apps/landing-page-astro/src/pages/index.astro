---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import CatchStrip from '@/components/CatchStrip.astro';
import Stats from '@/components/Stats.astro';
import Bento from '@/components/Bento.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import Providers from '@/components/Providers.astro';
import Pricing from '@/components/Pricing.astro';
import CTA from '@/components/CTA.astro';
import Footer from '@/components/Footer.astro';

// CodeVetter landing — Astro static port of apps/landing-page/app/page.tsx.
// Composition mirrors the React page 1:1.
---

<Layout
  title="CodeVetter — Vet AI-generated code before it ships"
  description="Desktop-first code review for agent-generated code. Runs offline. Multi-LLM. Catches what your agent misses."
  path="/"
>
  <main>
    <Nav />
    <Hero />
    {/* Everything below the hero is wrapped in `content-visibility:auto`
        so the browser skips layout/paint until each section enters the
        viewport. Drops first-paint cost from 951 DOM elements down to
        the ~250 the hero needs. See globals.css → `.cv-below-fold`. */}
    <div class="cv-below-fold"><CatchStrip /></div>
    <div class="cv-below-fold"><Stats /></div>
    <div class="cv-below-fold"><Bento /></div>
    <div class="cv-below-fold"><HowItWorks /></div>
    <div class="cv-below-fold"><Providers /></div>
    <div class="cv-below-fold"><Pricing /></div>
    <div class="cv-below-fold"><CTA /></div>
    <div class="cv-below-fold"><Footer /></div>
  </main>
</Layout>
