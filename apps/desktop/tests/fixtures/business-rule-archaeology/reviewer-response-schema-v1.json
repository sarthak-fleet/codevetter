{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codevetter.local/schemas/business-rule-archaeology-reviewer-response-v1.json",
  "title": "Business-rule archaeology human reviewer response",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "packet_id", "packet_sha256", "reviewer", "items"],
  "properties": {
    "schema_version": { "const": 1 },
    "contract_id": {
      "const": "codevetter.business-rule-archaeology.reviewer-response.v1"
    },
    "packet_id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "packet_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "actor_id", "authority_id"],
      "properties": {
        "kind": { "const": "human" },
        "actor_id": { "type": "string", "pattern": "^human:.+", "maxLength": 256 },
        "authority_id": { "type": "null" }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "rule_id",
          "active_review_seconds",
          "decision",
          "corrected_clauses",
          "note"
        ],
        "properties": {
          "item_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "rule_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "active_review_seconds": { "type": "integer", "minimum": 1 },
          "decision": {
            "enum": ["accept", "correct", "reject", "unable_to_assess"]
          },
          "corrected_clauses": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["clause_id", "corrected_text"],
              "properties": {
                "clause_id": { "type": "string", "minLength": 1, "maxLength": 256 },
                "corrected_text": { "type": "string", "minLength": 1, "maxLength": 16384 }
              }
            }
          },
          "note": { "type": ["string", "null"], "maxLength": 4096 }
        }
      }
    }
  }
}
